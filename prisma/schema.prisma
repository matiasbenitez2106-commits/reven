// trato — esquema de base de datos
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

// Estado de verificación de identidad del usuario
enum VerificationStatus {
  UNVERIFIED // registrado, todavía no envió documentación
  PENDING // envió documentación, en revisión
  VERIFIED // identidad confirmada
  REJECTED // rechazado
}

// Condición del artículo: bueno / muy bueno / como nuevo
enum Condition {
  GOOD
  VERY_GOOD
  LIKE_NEW
}

enum ListingStatus {
  ACTIVE
  RESERVED // oferta aceptada: reservada hasta confirmar la venta (o liberar)
  SOLD
  PAUSED
  DELETED
}

// Planes de publicación destacada
enum PaymentType {
  BOOST_3 // Boost 3 días
  FEATURED_7 // Destacado 7 días
  FEATURED_14 // Destacado 14 días
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// Planes de suscripción del vendedor
enum SubscriptionPlan {
  PRO
  PRO_PLUS
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
}

// ──────────────────────────────────────────────
// Modelos
// ──────────────────────────────────────────────

model User {
  id                     String             @id @default(cuid())
  firstName              String
  lastName               String
  email                  String             @unique
  emailVerified          DateTime?
  passwordHash           String
  province               String
  city                   String
  // Ubicación aproximada del usuario (para búsquedas por proximidad)
  latitude               Float?
  longitude              Float?
  role                   Role               @default(USER)
  verification           VerificationStatus @default(UNVERIFIED)
  avatarUrl              String?
  // Suspensión por un admin: bloquea el login y pausa sus publicaciones
  suspendedAt            DateTime?
  // Baja de cuenta en dos fases (ver docs/plan-borrado-dos-fases.md). Todos
  // opcionales y vacíos por defecto: NO afectan a las cuentas existentes.
  deletionRequestedAt    DateTime? // cuándo el usuario pidió la baja
  deletionScheduledFor   DateTime? // fecha de borrado definitivo (pedido + 90 días)
  legalHoldAt            DateTime? // marca de "bloqueada por motivo legal" (null = no bloqueada)
  deletionReminderSentAt DateTime? // cuándo se mandó el email recordatorio (para no repetirlo)
  // Suscripción de vendedor (desnormalizado para ranking/badge)
  proPlan                SubscriptionPlan?
  proUntil               DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  verificationData      Verification?
  subscription          Subscription?
  listings              Listing[]
  favorites             Favorite[]
  payments              Payment[]
  conversationsAsBuyer  Conversation[] @relation("BuyerConversations")
  conversationsAsSeller Conversation[] @relation("SellerConversations")
  messages              Message[]      @relation("SentMessages")
  reportsMade           Report[]       @relation("ReportsMade")
  authTokens            AuthToken[]
  notifications         Notification[]
  reviewsWritten        Review[]       @relation("ReviewsWritten")
  reviewsReceived       Review[]       @relation("ReviewsReceived")
  purchases             Listing[]      @relation("Purchases")
  offersMade            Offer[]        @relation("OffersMade")
  offersReceived        Offer[]        @relation("OffersReceived")
  offersProposed        Offer[]        @relation("OffersProposed")

  @@index([verification])
}

// Datos sensibles de verificación. Los campos personales se guardan ENCRIPTADOS
// (AES-256-GCM, ver src/lib/crypto.ts). Solo accesibles por un admin ante denuncia.
model Verification {
  id              String             @id @default(cuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          VerificationStatus @default(PENDING)
  provider        String             @default("mock") // mock | onfido
  providerRef     String? // id del check en el proveedor externo
  // URLs encriptadas (las imágenes viven en almacenamiento privado)
  dniFrontUrlEnc  String?
  dniBackUrlEnc   String?
  selfieUrlEnc    String?
  // Nº de documento encriptado
  dniNumberEnc    String?
  // Hash (HMAC) del Nº de DNI para garantizar 1 cuenta por persona física.
  dniHash         String?
  livenessScore   Float? // resultado del liveness check (0..1)
  matchScore      Float? // similitud selfie vs DNI (0..1)
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedBy      String? // id del admin o "system"
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  icon     String? // nombre de ícono (lucide)
  order    Int       @default(0)
  listings Listing[]
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  description String
  price       Decimal       @db.Decimal(12, 2)
  currency    String        @default("ARS")
  condition   Condition
  status      ListingStatus @default(ACTIVE)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  // Ubicación del artículo
  province     String
  city         String
  neighborhood String?
  latitude     Float?
  longitude    Float?

  sellerId String
  seller   User   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  // Comprador al que se vendió (se setea al marcar la publicación como vendida).
  // Opcional; onDelete: SetNull → si se borra ese usuario, la venta queda sin comprador.
  soldToId String?
  soldTo   User?   @relation("Purchases", fields: [soldToId], references: [id], onDelete: SetNull)

  images        ListingImage[]
  conversations Conversation[]
  favorites     Favorite[]
  payments      Payment[]
  reports       Report[]
  reviews       Review[]
  offers        Offer[]

  // Publicación destacada (monetización): vigente mientras featuredUntil > now()
  featuredUntil DateTime?
  viewCount     Int       @default(0)

  // Si la publicación se pausó por la BAJA de cuenta del dueño (ver
  // docs/plan-borrado-dos-fases.md). Permite, al reactivar, despausar SOLO estas
  // y no las que el dueño ya había pausado a propósito. Opcional, vacío por defecto.
  deletionPausedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  soldAt    DateTime?

  @@index([status])
  @@index([categoryId])
  @@index([price])
  @@index([createdAt])
  @@index([sellerId])
  @@index([featuredUntil])
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  publicId  String? // id en Cloudinary (para poder borrarla)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([listingId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model Conversation {
  id        String    @id @default(cuid())
  listingId String
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId  String
  seller    User      @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Un comprador tiene una sola conversación por publicación
  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

// Pagos de publicaciones destacadas (MercadoPago). Sin comisiones entre partes.
model Payment {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId      String
  listing        Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  type           PaymentType
  amount         Int // ARS (sin decimales)
  status         PaymentStatus @default(PENDING)
  mpPreferenceId String?
  mpPaymentId    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
  @@index([listingId])
}

// Suscripción del vendedor (PRO / PRO+). Recurrente vía MercadoPago (preapproval).
model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             SubscriptionPlan
  // Cambio de plan programado para aplicarse en la próxima renovación (sin recobro
  // inmediato): si el usuario pasa de PRO+ a PRO mientras tiene plan activo.
  pendingPlan      SubscriptionPlan?
  status           SubscriptionStatus @default(PENDING)
  currentPeriodEnd DateTime
  boostsIncluded   Int                @default(0)
  boostsUsed       Int                @default(0)
  mpPreapprovalId  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

// Motivo de la denuncia de una publicación
enum ReportReason {
  FRAUD // estafa
  FAKE // producto falso / inexistente
  PROHIBITED // artículo prohibido
  SPAM // spam / publica cualquier cosa
  OTHER
}

enum ReportStatus {
  PENDING // sin revisar
  REVIEWED // revisada, sin acción
  DISMISSED // desestimada
  ACTIONED // se tomó acción (p.ej. se eliminó la publicación)
}

// Denuncia de una publicación (la hace un comprador; la revisa un admin)
model Report {
  id         String       @id @default(cuid())
  listingId  String
  listing    Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User         @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reason     ReportReason
  details    String?
  status     ReportStatus @default(PENDING)
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime     @default(now())

  // Un usuario denuncia una publicación una sola vez
  @@unique([reporterId, listingId])
  @@index([status])
  @@index([listingId])
}

// Tokens para verificación de email y recuperación de contraseña.
// Se guarda el HASH del token (no el valor en claro).
enum TokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model AuthToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TokenType
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Notificaciones in-app (campanita)
enum NotificationType {
  MESSAGE
  CONTACT
  VERIFICATION
  REPORT
  SUBSCRIPTION
  OFFER
  REVIEW
  GENERIC
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// Mensajes de contacto/soporte/privacidad. Se reciben por el formulario de la app
// y aparecen en el panel de administración (además de avisarse por email al admin).
enum SupportTopic {
  SOPORTE
  PRIVACIDAD
  DENUNCIA
  OTRO
}

enum SupportStatus {
  OPEN
  CLOSED
}

model SupportMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  topic     SupportTopic  @default(SOPORTE)
  message   String
  status    SupportStatus @default(OPEN)
  // Usuario logueado que lo envió (si corresponde)
  userId    String?
  createdAt DateTime      @default(now())

  @@index([status, createdAt])
}

// Rol del CALIFICADO en la transacción: separa "reputación como vendedor" (feed)
// de "reputación como comprador" (ofertas), para que NO se mezclen.
enum ReviewTargetRole {
  SELLER
  BUYER
}

// Calificación atada a una venta concreta, en DOBLE sentido (comprador↔vendedor).
// rating 1..5; un autor califica una publicación una sola vez (@@unique listingId+authorId).
model Review {
  id         String           @id @default(cuid())
  rating     Int
  comment    String?
  listingId  String
  listing    Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  authorId   String
  author     User             @relation("ReviewsWritten", fields: [authorId], references: [id], onDelete: Cascade)
  targetId   String
  target     User             @relation("ReviewsReceived", fields: [targetId], references: [id], onDelete: Cascade)
  // @default(SELLER) backfillea el legado (todo era comprador→vendedor); las
  // reseñas nuevas lo setean explícito desde la eligibility.
  targetRole ReviewTargetRole @default(SELLER)
  createdAt  DateTime         @default(now())

  @@unique([listingId, authorId])
  @@index([targetId, targetRole])
}

// ──────────────────────────────────────────────
// Ofertas (estilo Depop): negociación de precio entre comprador y vendedor.
// ──────────────────────────────────────────────

enum OfferStatus {
  PENDING // vigente, esperando respuesta de la otra parte
  ACCEPTED // aceptada → la publicación pasa a RESERVED
  REJECTED // rechazada por quien la recibió
  COUNTERED // superada por una contraoferta (su hija PENDING es la vigente)
  EXPIRED // venció a las 48 hs sin respuesta
  CANCELLED // retirada por quien la propuso
}

// Una oferta sobre una publicación. Las contraofertas son filas nuevas ligadas
// por parentOfferId; `proposedById` dice quién propuso ESTA oferta (comprador o
// vendedor) — explícito, sin inferir por la cadena. La vigente de un hilo es la
// hoja PENDING. sellerId se deriva SIEMPRE de listing.sellerId en el backend.
model Offer {
  id            String      @id @default(cuid())
  listingId     String
  listing       Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId       String
  buyer         User        @relation("OffersMade", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        User        @relation("OffersReceived", fields: [sellerId], references: [id], onDelete: Cascade)
  proposedById  String
  proposedBy    User        @relation("OffersProposed", fields: [proposedById], references: [id], onDelete: Cascade)
  amount        Int // ARS, sin decimales
  status        OfferStatus @default(PENDING)
  message       String?
  // Contraofertas: oferta padre de la que esta es contraoferta (self-relation).
  parentOfferId String?
  parent        Offer?      @relation("OfferThread", fields: [parentOfferId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  counters      Offer[]     @relation("OfferThread")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  expiresAt     DateTime

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}
